{ ... }: {
  # REQUIRED — copy this file to local.nix before your first rebuild.
  #   cp hosts/laptop/local.nix.example hosts/laptop/local.nix
  #
  # NixOS-only overrides (imported by configuration.nix).
  # For theme/app overrides shared with Home Manager, use shared.nix.
  # For HM-only options, use home.local.nix.
  #
  # gitignored — stage with: git add -f hosts/laptop/local.nix

  # ── System (NixOS) overrides ─────────────────────────────────────────────────
  #
  # Machine-specific settings that should not apply to every host using this flake:
  # networking.hostName = "laptop";
  # time.timeZone = "Europe/Dublin";
  # boot.kernelModules = [ "kvm-intel" ];
  # environment.systemPackages = with pkgs; [ libva-utils mesa-demos ];

  # ── GPU driver (required on a new machine — enable exactly one) ─────────────
  #
  #   lspci -k | grep -A 3 -E 'VGA|3D|Display'
  #
  # nesw.drivers.intel.enable = true;   # i915 / xe — most Intel laptops
  # nesw.drivers.amdgpu.enable = true;  # AMD Ryzen iGPU / dGPU
  # nesw.drivers.nvidia.enable = true;  # proprietary NVIDIA (open = true on Turing+)

  # ── Theme, fonts, Hyprland apps → put these in shared.nix, not here ──────────
  #
  # nesw.theme.fonts.sansSerif = "Inter";
  # nesw.desktop.hyprland.browser = "firefox";
  #
  # See local.nix.example sections in the repo history, or modules/themes/default.nix.

  # ── Home Manager overrides → use home.local.nix, not local.nix ───────────────
  #
  # home.packages = [ pkgs.ripgrep ];
  # programs.git.enable = true;
}
